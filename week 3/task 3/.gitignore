# Python cache files (created automatically, don't need to upload these)
__pycache__/
*.py[cod]
*.pyo

# Virtual environment folders (if you use one)
venv/
env/
.venv/

# VS Code settings (personal editor settings, not needed by others)
.vscode/

# PyCharm settings
.idea/

# OS-generated files
.DS_Store        # Mac
Thumbs.db        # Windows

# Logs and temp files
*.log
*.tmp
